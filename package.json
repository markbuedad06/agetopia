{
  "name": "agetopia",
  "version": "1.0.0",
  "private": true,
  "description": "Growtopia-like sandbox with online multiplayer, accounts, and MySQL persistence",
  "main": "server.js",
  "scripts": {
    "server": "node server.js",
    "start": "node server.js",
    "autosync": "powershell -NoProfile -ExecutionPolicy Bypass -File ./auto-sync.ps1",
    "autosync:all": "powershell -NoProfile -ExecutionPolicy Bypass -File ./auto-sync.ps1 -IncludeUntracked"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.4",
    "ws": "^8.18.1"
  }
}
